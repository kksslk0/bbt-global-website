---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative overflow-hidden px-5 pb-20 pt-20 sm:px-6 md:pb-28 md:pt-28">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/60 to-transparent"></div>
  <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[1.02fr_0.98fr]">
    <div>
      <div class="mb-7 inline-flex items-center gap-2 rounded-full border border-primary/25 bg-primary/8 px-3 py-1.5">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-60"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
        </span>
        <span class="text-xs font-semibold uppercase tracking-[0.16em] text-primary/90">
          {t('home.eyebrow')}
        </span>
      </div>

      <h1 class="max-w-4xl text-5xl font-bold leading-[0.96] tracking-tight text-foreground sm:text-6xl md:text-7xl">
        <span class="block">BBT Global</span>
        <span class="mt-3 block text-balance text-primary">
          {t('home.heroLine')}
        </span>
      </h1>

      <p class="mt-7 max-w-2xl text-lg leading-8 text-muted-foreground md:text-xl">
        {t('home.subtitle')}
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a
          href={`/${lang}/download`}
          class="inline-flex h-12 items-center justify-center gap-2 rounded-lg bg-primary px-7 text-sm font-bold text-primary-foreground shadow-[0_18px_50px_rgba(44,225,181,0.2)] transition-all hover:-translate-y-0.5 hover:bg-primary/90"
        >
          {t('cta.download')}
        </a>
        <a
          href={`/${lang}/whitepaper`}
          class="inline-flex h-12 items-center justify-center gap-2 rounded-lg border border-white/12 bg-white/[0.035] px-7 text-sm font-semibold text-foreground transition-all hover:-translate-y-0.5 hover:border-primary/35 hover:bg-white/[0.07]"
        >
          {t('cta.whitepaper')}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <div class="mt-12 grid max-w-xl grid-cols-3 gap-px overflow-hidden rounded-lg border border-white/10 bg-white/10">
        {[
          { k: t('home.stat.identity'), v: 'Wallet' },
          { k: t('home.stat.messages'), v: 'Realtime' },
          { k: t('home.stat.language'), v: '100+' },
        ].map(item => (
          <div class="bg-background/88 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-muted-foreground">{item.k}</p>
            <p class="mt-2 text-sm font-semibold text-foreground">{item.v}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="relative min-h-[440px] lg:min-h-[560px]">
      <div class="absolute inset-0 rounded-[2rem] border border-white/10 bg-[linear-gradient(135deg,rgba(255,255,255,0.08),rgba(255,255,255,0.02))] shadow-2xl shadow-black/30"></div>
      <div class="absolute left-6 right-6 top-6 rounded-xl border border-white/10 bg-background/82 p-4 shadow-xl backdrop-blur">
        <div class="mb-5 flex items-center justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Network</p>
            <p class="mt-1 text-lg font-semibold">BBT Social Mesh</p>
          </div>
          <span class="rounded-full border border-primary/25 bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">Live</span>
        </div>
        <div class="space-y-3">
          {[
            { a: '0x7A...B19', b: t('home.network.identityCheck'), p: '98%' },
            { a: 'DAO-CN-08', b: t('home.network.crossLanguage'), p: '74%' },
            { a: 'NFT Gate', b: t('home.network.memberAccess'), p: '61%' },
          ].map(row => (
            <div class="rounded-lg border border-white/8 bg-white/[0.035] p-3">
              <div class="flex items-center justify-between gap-3 text-sm">
                <span class="font-mono text-foreground">{row.a}</span>
                <span class="text-muted-foreground">{row.b}</span>
              </div>
              <div class="mt-3 h-1.5 overflow-hidden rounded-full bg-white/8">
                <div class="h-full rounded-full bg-primary" style={`width: ${row.p}`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="absolute bottom-8 left-0 w-[72%] rounded-xl border border-white/10 bg-card/88 p-4 shadow-2xl shadow-black/30 backdrop-blur">
        <div class="mb-4 flex items-center gap-2">
          <span class="h-2.5 w-2.5 rounded-full bg-primary"></span>
          <span class="text-xs uppercase tracking-[0.18em] text-muted-foreground">Translator</span>
        </div>
        <p class="text-sm leading-6 text-muted-foreground">{t('home.translatorNote')}</p>
        <div class="mt-4 grid grid-cols-3 gap-2 text-center text-xs">
          <span class="rounded-md bg-white/[0.055] px-2 py-2">ZH</span>
          <span class="rounded-md bg-primary/15 px-2 py-2 text-primary">EN</span>
          <span class="rounded-md bg-white/[0.055] px-2 py-2">KR</span>
        </div>
      </div>

      <div class="absolute bottom-0 right-0 w-[48%] rounded-xl border border-primary/20 bg-primary/10 p-4 shadow-xl backdrop-blur">
        <p class="text-xs uppercase tracking-[0.18em] text-primary/90">Token Gate</p>
        <p class="mt-5 text-3xl font-bold">BBT</p>
        <p class="mt-1 text-xs text-muted-foreground">{t('home.tokenGatePassed')}</p>
      </div>
    </div>
  </div>
</section>
