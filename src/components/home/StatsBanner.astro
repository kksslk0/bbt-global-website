---
const stats = [
  { value: '—', labelZh: '活跃用户', labelEn: 'Active Users' },
  { value: '—', labelZh: '社区数量', labelEn: 'Communities' },
  { value: '—', labelZh: '支持语言', labelEn: 'Languages' },
];
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="px-6 pb-32">
  <div class="mx-auto max-w-4xl">
    <div class="grid grid-cols-3 divide-x divide-[var(--color-border)] rounded-2xl border border-[var(--color-border-strong)] bg-[var(--color-bg-card)] backdrop-blur-xl">
      {stats.map((s, i) => (
        <div class="py-10 text-center">
          <p class="text-4xl font-bold bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent">{s.value}</p>
          <p class="mt-2 text-xs font-medium text-[var(--color-text-muted)]">
            {lang === 'zh' ? s.labelZh : s.labelEn}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
