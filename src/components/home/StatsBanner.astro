---
const stats = [
  { value: '—', labelZh: '活跃用户', labelEn: 'Active Users' },
  { value: '—', labelZh: '社区数量', labelEn: 'Communities' },
  { value: '—', labelZh: '支持语言', labelEn: 'Languages' },
];
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="px-5 pb-24 sm:px-6">
  <div class="mx-auto max-w-7xl">
    <div class="grid overflow-hidden rounded-xl border border-white/10 bg-white/[0.035] sm:grid-cols-3">
      {stats.map(s => (
        <div class="border-b border-white/10 p-8 sm:border-b-0 sm:border-r sm:last:border-r-0 md:p-10">
          <p class="font-mono text-4xl font-bold text-primary">{s.value}</p>
          <p class="mt-3 text-xs font-semibold uppercase tracking-[0.16em] text-muted-foreground">
            {lang === 'zh' ? s.labelZh : s.labelEn}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
