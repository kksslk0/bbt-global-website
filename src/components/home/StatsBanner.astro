---
const stats = [
  { value: '—', labelZh: '活跃用户', labelEn: 'Active Users' },
  { value: '—', labelZh: '社区数量', labelEn: 'Communities' },
  { value: '—', labelZh: '支持语言', labelEn: 'Languages' },
];
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="px-6 pb-24">
  <div class="mx-auto max-w-3xl">
    <div class="grid grid-cols-3 divide-x rounded-xl border bg-card">
      {stats.map(s => (
        <div class="py-10 text-center">
          <p class="text-4xl font-bold">{s.value}</p>
          <p class="mt-2 text-xs font-medium text-muted-foreground">
            {lang === 'zh' ? s.labelZh : s.labelEn}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
