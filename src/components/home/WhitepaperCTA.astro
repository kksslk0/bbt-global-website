---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="px-5 pb-24 sm:px-6">
  <div class="mx-auto grid max-w-7xl overflow-hidden rounded-xl border border-white/10 bg-white/[0.035] md:grid-cols-[0.9fr_1.1fr]">
    <div class="border-b border-white/10 p-8 md:border-b-0 md:border-r md:p-10">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">
        BBT Paper
      </p>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">{t('whitepaper.title')}</h2>
      <p class="mt-4 leading-7 text-muted-foreground">{t('whitepaper.subtitle')}</p>
      <a
        href="/whitepaper.pdf"
        download
        class="mt-8 inline-flex h-11 items-center gap-2 rounded-lg bg-primary px-6 text-sm font-bold text-primary-foreground transition-all hover:-translate-y-0.5 hover:bg-primary/90"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        {t('cta.whitepaper')}
      </a>
    </div>
    <div class="p-8 md:p-10">
      <p class="mb-5 text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">
      {lang === 'zh' ? '深度了解' : 'Deep Dive'}
    </p>
      <div class="grid gap-3 sm:grid-cols-3">
        {[
          lang === 'zh' ? '技术架构' : 'Architecture',
          lang === 'zh' ? '代币经济' : 'Tokenomics',
          lang === 'zh' ? '生态路线' : 'Roadmap',
        ].map(item => (
          <div class="rounded-lg border border-white/10 bg-background/70 p-4">
            <div class="mb-5 h-1.5 w-10 rounded-full bg-primary"></div>
            <p class="text-sm font-semibold">{item}</p>
          </div>
        ))}
      </div>
      <div class="mt-5 rounded-lg border border-white/10 bg-background/70 p-5 font-mono text-xs leading-6 text-muted-foreground">
        <p>BBT://protocol/identity</p>
        <p>BBT://social/token-gate</p>
        <p>BBT://translate/context</p>
      </div>
    </div>
  </div>
</section>
