---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="px-6 pb-32">
  <div class="mx-auto max-w-4xl relative overflow-hidden rounded-3xl border border-[var(--color-border-strong)] bg-[var(--color-bg-card)] backdrop-blur-xl p-12 md:p-16 text-center">
    <div class="absolute top-0 right-0 w-[300px] h-[300px] rounded-full bg-[var(--color-glow-blue)] blur-[100px] pointer-events-none translate-x-1/2 -translate-y-1/2"></div>

    <div class="relative z-10">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-muted)]">
        {lang === 'zh' ? '深度了解' : 'Deep Dive'}
      </p>
      <h2 class="text-3xl font-bold md:text-4xl">{t('whitepaper.title')}</h2>
      <p class="mt-4 text-[var(--color-text-secondary)] max-w-md mx-auto">{t('whitepaper.subtitle')}</p>
      <a
        href="/whitepaper.pdf"
        download
        class="mt-10 inline-flex items-center gap-2.5 rounded-xl bg-white px-8 py-3.5 text-sm font-semibold text-black shadow-lg shadow-white/10 transition-all hover:shadow-xl hover:shadow-white/20 hover:scale-[1.02]"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        {t('cta.whitepaper')}
      </a>
    </div>
  </div>
</section>
