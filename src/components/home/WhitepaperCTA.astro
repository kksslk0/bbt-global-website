---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="px-6 pb-24">
  <div class="mx-auto max-w-4xl rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-12 text-center">
    <h2 class="text-2xl font-bold md:text-3xl">{t('whitepaper.title')}</h2>
    <p class="mt-3 text-[var(--color-text-secondary)]">{t('whitepaper.download')}</p>
    <a
      href="/whitepaper.pdf"
      download
      class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-8 py-3 text-sm font-semibold text-black transition-all hover:bg-gray-200"
    >
      {t('cta.whitepaper')}
    </a>
  </div>
</section>
