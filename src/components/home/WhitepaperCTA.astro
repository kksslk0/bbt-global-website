---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="px-6 pb-24">
  <div class="mx-auto max-w-3xl rounded-xl border bg-card p-12 text-center">
    <p class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-muted-foreground">
      {lang === 'zh' ? '深度了解' : 'Deep Dive'}
    </p>
    <h2 class="text-2xl font-bold tracking-tight">{t('whitepaper.title')}</h2>
    <p class="mt-3 text-muted-foreground">{t('whitepaper.subtitle')}</p>
    <a
      href="/whitepaper.pdf"
      download
      class="mt-8 inline-flex h-11 items-center gap-2 rounded-lg bg-primary px-8 text-sm font-semibold text-primary-foreground shadow transition-colors hover:bg-primary/90"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      {t('cta.whitepaper')}
    </a>
  </div>
</section>
