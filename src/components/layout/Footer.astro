---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const footerLinks = [
  {
    title: { zh: '产品', en: 'Products' },
    links: [
      { label: { zh: '翻译器', en: 'Translator' }, href: `/${lang}/products/translator` },
      { label: { zh: '社交', en: 'Social' }, href: `/${lang}/products/social` },
      { label: { zh: '教育', en: 'Education' }, href: `/${lang}/products/education` },
    ],
  },
  {
    title: { zh: '资源', en: 'Resources' },
    links: [
      { label: { zh: '白皮书', en: 'Whitepaper' }, href: `/${lang}/whitepaper` },
      { label: { zh: '下载', en: 'Download' }, href: `/${lang}/download` },
      { label: { zh: '关于我们', en: 'About' }, href: `/${lang}/about` },
    ],
  },
];
---

<footer class="border-t bg-card">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <div class="flex items-center gap-2 mb-4 font-semibold">
          <div class="flex h-8 w-8 items-center justify-center rounded-md bg-primary text-primary-foreground text-sm font-bold">
            B
          </div>
          BBT<span class="text-primary"> Global</span>
        </div>
        <p class="text-sm text-muted-foreground">{t('footer.tagline')}</p>
      </div>

      {footerLinks.map(col => (
        <div>
          <h4 class="mb-3 text-sm font-semibold">{col.title[lang]}</h4>
          <ul class="space-y-2">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">
                  {link.label[lang]}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 border-t pt-8">
      <p class="text-center text-xs text-muted-foreground">
        &copy; {new Date().getFullYear()} {t('footer.copyright')}
      </p>
    </div>
  </div>
</footer>
