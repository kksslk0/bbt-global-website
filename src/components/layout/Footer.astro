---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const footerLinks = [
  {
    title: t('nav.products'),
    links: [
      { label: t('nav.translator'), href: `/${lang}/products/translator` },
      { label: t('nav.social'), href: `/${lang}/products/social` },
      { label: t('nav.education'), href: `/${lang}/products/education` },
    ],
  },
  {
    title: t('footer.resources'),
    links: [
      { label: t('nav.whitepaper'), href: `/${lang}/whitepaper` },
      { label: t('nav.download'), href: `/${lang}/download` },
      { label: t('nav.about'), href: `/${lang}/about` },
    ],
  },
];
---

<footer class="border-t border-white/10 bg-background/90">
  <div class="mx-auto max-w-7xl px-5 py-12 sm:px-6">
    <div class="grid gap-10 md:grid-cols-[1.3fr_0.7fr_0.7fr]">
      <div>
        <div class="mb-4 flex items-center gap-3 font-semibold tracking-tight">
          <img
            src="/brand/bbt-logo.png"
            alt=""
            class="h-9 w-9 rounded-lg border border-primary/25 object-cover"
          />
          <span>BBT<span class="text-primary"> Global</span></span>
        </div>
        <p class="max-w-sm text-sm leading-6 text-muted-foreground">{t('footer.tagline')}</p>
      </div>

      {footerLinks.map(col => (
        <div>
          <h4 class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-foreground">{col.title}</h4>
          <ul class="space-y-2">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 border-t border-white/10 pt-8">
      <p class="text-xs text-muted-foreground">
        &copy; {new Date().getFullYear()} {t('footer.copyright')}
      </p>
    </div>
  </div>
</footer>
