---
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const footerLinks = [
  {
    title: { zh: '产品', en: 'Products' },
    links: [
      { label: { zh: '翻译器', en: 'Translator' }, href: `/${lang}/products/translator` },
      { label: { zh: '社交', en: 'Social' }, href: `/${lang}/products/social` },
      { label: { zh: '教育', en: 'Education' }, href: `/${lang}/products/education` },
    ],
  },
  {
    title: { zh: '资源', en: 'Resources' },
    links: [
      { label: { zh: '白皮书', en: 'Whitepaper' }, href: `/${lang}/whitepaper` },
      { label: { zh: '下载', en: 'Download' }, href: `/${lang}/download` },
      { label: { zh: '关于我们', en: 'About' }, href: `/${lang}/about` },
    ],
  },
];
---

<footer class="border-t border-white/10 bg-background/90">
  <div class="mx-auto max-w-7xl px-5 py-12 sm:px-6">
    <div class="grid gap-10 md:grid-cols-[1.3fr_0.7fr_0.7fr]">
      <div>
        <div class="mb-4 flex items-center gap-3 font-semibold tracking-tight">
          <div class="relative flex h-9 w-9 items-center justify-center rounded-lg border border-primary/35 bg-primary/12 text-sm font-bold text-primary">
            <span class="absolute inset-1 rounded-[5px] border border-white/10"></span>
            <span>B</span>
          </div>
          <span>BBT<span class="text-primary"> Global</span></span>
        </div>
        <p class="max-w-sm text-sm leading-6 text-muted-foreground">{t('footer.tagline')}</p>
      </div>

      {footerLinks.map(col => (
        <div>
          <h4 class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-foreground">{col.title[lang]}</h4>
          <ul class="space-y-2">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground">
                  {link.label[lang]}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 border-t border-white/10 pt-8">
      <p class="text-xs text-muted-foreground">
        &copy; {new Date().getFullYear()} {t('footer.copyright')}
      </p>
    </div>
  </div>
</footer>
