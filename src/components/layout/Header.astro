---
import LanguagePicker from '../shared/LanguagePicker.tsx';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

const navItems = [
  { label: t('nav.products'), href: `/${lang}/products/social` },
  { label: t('nav.whitepaper'), href: `/${lang}/whitepaper` },
  { label: t('nav.download'), href: `/${lang}/download` },
  { label: t('nav.about'), href: `/${lang}/about` },
];

function isActive(itemHref: string, current: string): boolean {
  return current.startsWith(itemHref);
}
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="mx-auto max-w-7xl px-6 py-4">
    <nav class="flex items-center justify-between rounded-2xl border border-[var(--color-border-strong)] bg-[rgba(10,10,18,0.7)] backdrop-blur-2xl px-5 py-3">
      <a href={`/${lang}`} class="flex items-center gap-2.5 group">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-accent-soft)]">
          <span class="text-sm font-bold text-white">B</span>
        </div>
        <span class="text-base font-semibold tracking-tight text-white">BBT<span class="text-[var(--color-accent)]"> Global</span></span>
      </a>

      <div class="hidden items-center gap-1 md:flex">
        {navItems.map(item => (
          <a
            href={item.href}
            class={`relative rounded-lg px-3.5 py-2 text-sm font-medium transition-all duration-200 ${
              isActive(item.href, currentPath)
                ? 'text-white bg-white/[0.06]'
                : 'text-[var(--color-text-secondary)] hover:text-white hover:bg-white/[0.03]'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3">
        <LanguagePicker lang={lang} currentPath={currentPath} client:load />
      </div>
    </nav>
  </div>
</header>

<div class="h-[89px]"></div>
