---
import LanguagePicker from '../shared/LanguagePicker.tsx';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

const navItems = [
  { label: t('nav.products'), href: `/${lang}/products/social` },
  { label: t('nav.whitepaper'), href: `/${lang}/whitepaper` },
  { label: t('nav.download'), href: `/${lang}/download` },
  { label: t('nav.about'), href: `/${lang}/about` },
];

function isActive(itemHref: string, current: string): boolean {
  return current.startsWith(itemHref);
}
---

<header class="sticky top-0 z-50 border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 h-16">
    <a href={`/${lang}`} class="flex items-center gap-2 font-semibold text-lg">
      <div class="flex h-8 w-8 items-center justify-center rounded-md bg-primary text-primary-foreground text-sm font-bold">
        B
      </div>
      BBT<span class="text-primary"> Global</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`px-3 py-2 text-sm font-medium rounded-md transition-colors ${
            isActive(item.href, currentPath)
              ? 'text-foreground bg-accent'
              : 'text-muted-foreground hover:text-foreground hover:bg-accent'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <LanguagePicker lang={lang} currentPath={currentPath} client:load />
    </div>
  </div>
</header>
