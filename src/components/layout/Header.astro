---
import LanguagePicker from '../shared/LanguagePicker.tsx';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/dict';

export interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

const navItems = [
  { label: t('nav.products'), href: `/${lang}/products/social` },
  { label: t('nav.whitepaper'), href: `/${lang}/whitepaper` },
  { label: t('nav.download'), href: `/${lang}/download` },
  { label: t('nav.about'), href: `/${lang}/about` },
];

function isActive(itemHref: string, current: string): boolean {
  if (itemHref.endsWith('/products/social')) {
    return current.includes('/products/');
  }
  return current.startsWith(itemHref);
}
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-background/82 backdrop-blur-xl supports-[backdrop-filter]:bg-background/72">
  <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-y-3 px-5 py-3 sm:px-6">
    <a href={`/${lang}`} class="flex items-center gap-3 font-semibold text-lg tracking-tight">
      <div class="relative flex h-9 w-9 items-center justify-center rounded-lg border border-primary/35 bg-primary/12 text-sm font-bold text-primary shadow-[0_0_28px_rgba(44,225,181,0.16)]">
        <span class="absolute inset-1 rounded-[5px] border border-white/10"></span>
        <span>B</span>
      </div>
      <span>BBT<span class="text-primary"> Global</span></span>
    </a>

    <nav class="order-3 flex w-full items-center gap-1 overflow-x-auto rounded-full border border-white/10 bg-white/[0.035] p-1 md:order-none md:w-auto md:overflow-visible">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`shrink-0 rounded-full px-4 py-2 text-sm font-medium transition-colors ${
            isActive(item.href, currentPath)
              ? 'bg-primary text-primary-foreground'
              : 'text-muted-foreground hover:bg-white/[0.06] hover:text-foreground'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <LanguagePicker lang={lang} currentPath={currentPath} client:load />
    </div>
  </div>
</header>
