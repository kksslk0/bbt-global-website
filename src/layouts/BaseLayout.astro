---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ParticleBackground from '../components/shared/ParticleBackground.tsx';
import type { Lang } from '../i18n/dict';
import '../styles/global.css';

export interface Props {
  lang: Lang;
  title: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const fullTitle = `${title} — BBT Global`;
const dir = lang === 'ar' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={lang} dir={dir} class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={fullTitle} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:image" content="/og-image.png" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/brand/bbt-logo.png" />
</head>
<body class="min-h-screen bg-background text-foreground font-sans antialiased">
  <ParticleBackground client:load />
  <Header lang={lang} currentPath={Astro.url.pathname} />
  <main class="relative z-10">
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
