---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout lang="en" title="404 — Page Not Found">
  <section class="flex min-h-[60vh] items-center justify-center px-6">
    <div class="text-center">
      <h1 class="text-6xl font-bold">404</h1>
      <p class="mt-4 text-lg text-[var(--color-text-secondary)]">Page not found / 页面未找到</p>
      <a href="/" class="mt-8 inline-flex rounded-lg bg-white px-6 py-3 text-sm font-semibold text-black hover:bg-gray-200">
        Back Home / 返回首頁
      </a>
    </div>
  </section>
</BaseLayout>
