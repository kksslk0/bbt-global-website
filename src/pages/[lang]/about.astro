---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { langs } from '../../i18n/dict';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const content = {
  zh: {
    vision: 'BBT 致力於成為鏈上社交作業系統，透過 Web3 技術重構跨語言溝通、社群協作和教育學習體驗。',
    paragraphs: [
      'BBT 誕生於一個簡單的信念：語言不應該成為連接的障礙。我們構建了一個集翻譯、社交和教育於一體的 Web3 生態系統，利用區塊鏈技術保障使用者資料主權，透過 AI 實現無縫的跨語言溝通。',
      '我們的團隊由來自區塊鏈、人工智慧和語言教育的專業人士組成，分布在全球多個國家，致力於打造下一代社交基礎設施。',
    ],
    contact: '聯絡我們',
    email: 'contact@bbtglobal.io',
  },
  ja: {
    vision: 'BBT は Web3 技術によってクロスランゲージコミュニケーション、コミュニティ協働、教育体験を再構築するオンチェーン・ソーシャル OS を目指しています。',
    paragraphs: [
      'BBT は「言語はつながりの障壁であってはならない」というシンプルな信念から生まれました。翻訳、ソーシャル、教育を統合した Web3 エコシステムを構築し、ブロックチェーンでデータ主権を守り、AI でシームレスな多言語コミュニケーションを実現します。',
      'チームはブロックチェーン、AI、語学教育の専門家で構成され、複数の国に分散しながら次世代のソーシャルインフラを築いています。',
    ],
    contact: 'お問い合わせ',
    email: 'contact@bbtglobal.io',
  },
  en: {
    vision: 'BBT aims to become the on-chain social operating system, reimagining cross-language communication, community collaboration, and education through Web3 technology.',
    paragraphs: [
      'BBT was born from a simple belief: language should never be a barrier to connection. We are building a Web3 ecosystem that integrates translation, social networking, and education — empowering users with data sovereignty through blockchain and seamless cross-language communication through AI.',
      'Our team comprises professionals from blockchain, AI, and language education, distributed across multiple countries and united by the mission to build the next-generation social infrastructure.',
    ],
    contact: 'Contact Us',
    email: 'contact@bbtglobal.io',
  },
  ko: {
    vision: 'BBT는 Web3 기술로 다국어 소통, 커뮤니티 협업, 교육 경험을 재구성하는 온체인 소셜 운영 체제를 지향합니다.',
    paragraphs: [
      'BBT는 언어가 연결의 장벽이 되어서는 안 된다는 단순한 믿음에서 시작했습니다. 번역, 소셜, 교육을 결합한 Web3 생태계를 구축해 블록체인으로 데이터 주권을 보장하고 AI로 자연스러운 다국어 소통을 지원합니다.',
      '우리 팀은 블록체인, AI, 언어 교육 분야의 전문가들로 구성되어 있으며, 여러 국가에 분산되어 차세대 소셜 인프라를 만들고 있습니다.',
    ],
    contact: '문의하기',
    email: 'contact@bbtglobal.io',
  },
  hi: {
    vision: 'BBT Web3 तकनीक के माध्यम से बहुभाषी संवाद, समुदाय सहयोग और शिक्षा अनुभव को नया रूप देने वाला ऑन-चेन सोशल ऑपरेटिंग सिस्टम बनना चाहता है।',
    paragraphs: [
      'BBT एक सरल विश्वास से शुरू हुआ: भाषा जुड़ाव की बाधा नहीं होनी चाहिए। हम अनुवाद, सोशल और शिक्षा को जोड़ने वाला Web3 इकोसिस्टम बना रहे हैं, जहां blockchain डेटा स्वामित्व देता है और AI सहज बहुभाषी संवाद सक्षम करता है।',
      'हमारी टीम blockchain, AI और भाषा शिक्षा के पेशेवरों से बनी है, जो कई देशों में फैली है और अगली पीढ़ी का सोशल इंफ्रास्ट्रक्चर बना रही है।',
    ],
    contact: 'संपर्क करें',
    email: 'contact@bbtglobal.io',
  },
  es: {
    vision: 'BBT aspira a ser el sistema operativo social on-chain, reinventando la comunicación multilingüe, la colaboración comunitaria y el aprendizaje con tecnología Web3.',
    paragraphs: [
      'BBT nace de una idea simple: el idioma no debe ser una barrera para conectar. Construimos un ecosistema Web3 que integra traducción, social y educación, con soberanía de datos mediante blockchain y comunicación multilingüe fluida mediante IA.',
      'Nuestro equipo reúne profesionales de blockchain, IA y educación lingüística, distribuidos en varios países y unidos por la misión de construir la próxima infraestructura social.',
    ],
    contact: 'Contacto',
    email: 'contact@bbtglobal.io',
  },
  fr: {
    vision: 'BBT vise à devenir le système d’exploitation social on-chain, en réinventant la communication multilingue, la collaboration communautaire et l’apprentissage grâce au Web3.',
    paragraphs: [
      'BBT est né d’une conviction simple : la langue ne doit jamais être une barrière à la connexion. Nous construisons un écosystème Web3 qui réunit traduction, social et éducation, avec souveraineté des données via blockchain et communication multilingue fluide via IA.',
      'Notre équipe réunit des spécialistes de la blockchain, de l’IA et de l’éducation linguistique, répartis dans plusieurs pays et engagés dans la construction de la prochaine infrastructure sociale.',
    ],
    contact: 'Nous contacter',
    email: 'contact@bbtglobal.io',
  },
  ar: {
    vision: 'تهدف BBT إلى أن تصبح نظام تشغيل اجتماعيًا على السلسلة، يعيد تصور التواصل متعدد اللغات والتعاون المجتمعي والتعليم عبر تقنيات Web3.',
    paragraphs: [
      'وُلدت BBT من قناعة بسيطة: يجب ألا تكون اللغة حاجزًا أمام الاتصال. نحن نبني منظومة Web3 تجمع بين الترجمة والتواصل والتعليم، مع سيادة بيانات عبر blockchain وتواصل متعدد اللغات مدعوم بالذكاء الاصطناعي.',
      'يضم فريقنا خبراء في blockchain والذكاء الاصطناعي وتعليم اللغات، موزعين عبر عدة دول ومتحدين لبناء الجيل القادم من البنية الاجتماعية.',
    ],
    contact: 'اتصل بنا',
    email: 'contact@bbtglobal.io',
  },
};
---

<BaseLayout lang={lang} title={t('about.title')}>
  <section class="px-5 pb-24 pt-16 sm:px-6 md:pt-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">BBT Global</p>
          <h1 class="text-4xl font-bold tracking-tight md:text-6xl">{t('about.title')}</h1>
          <p class="mt-6 text-lg leading-8 text-muted-foreground">
            {content[lang].vision}
          </p>
        </div>

        <div class="space-y-4">
          {content[lang].paragraphs.map(p => (
            <p class="rounded-xl border border-white/10 bg-white/[0.035] p-6 leading-8 text-muted-foreground">{p}</p>
          ))}
        </div>
      </div>

      <div class="mt-12 rounded-xl border border-primary/20 bg-primary/10 p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-primary/90">{content[lang].contact}</p>
        <a href={`mailto:${content[lang].email}`} class="mt-3 inline-block text-2xl font-semibold text-foreground hover:text-primary">
          {content[lang].email}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
