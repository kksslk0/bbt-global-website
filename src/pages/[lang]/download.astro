---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DownloadSection from '../../components/product/DownloadSection.tsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { langs } from '../../i18n/dict';
import { products } from '../../config/downloads';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t('download.title')}>
  <section class="px-5 pb-12 pt-16 sm:px-6 md:pt-24">
    <div class="mx-auto max-w-7xl">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">Release Center</p>
      <h1 class="text-4xl font-bold tracking-tight md:text-6xl">{t('download.title')}</h1>
      <p class="mt-5 max-w-2xl text-lg leading-8 text-muted-foreground">
        {t('download.subtitle')}
      </p>
    </div>
  </section>

  <section class="space-y-8 px-5 pb-24 sm:px-6">
    <div class="mx-auto max-w-7xl space-y-4">
      {products.map(product => (
        <DownloadSection lang={lang} product={product} client:load />
      ))}
    </div>
  </section>
</BaseLayout>
