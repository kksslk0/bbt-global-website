---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroBanner from '../../components/home/HeroBanner.astro';
import ProductShowcase from '../../components/home/ProductShowcase.tsx';
import WhitepaperCTA from '../../components/home/WhitepaperCTA.astro';
import StatsBanner from '../../components/home/StatsBanner.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { langs, type Lang } from '../../i18n/dict';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title="BBT Global" description={t('home.subtitle')}>
  <HeroBanner lang={lang} />
  <ProductShowcase lang={lang} client:load />
  <WhitepaperCTA lang={lang} />
  <StatsBanner lang={lang} />
</BaseLayout>
