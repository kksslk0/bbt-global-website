---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FeatureList from '../../../components/product/FeatureList.tsx';
import DownloadSection from '../../../components/product/DownloadSection.tsx';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { langs } from '../../../i18n/dict';
import { products } from '../../../config/downloads';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const product = products.find(p => p.slug === 'education')!;

const features = [
  {
    icon: '🎓',
    title: { zh: '即時課堂', en: 'Live Classrooms', ja: 'ライブクラス', ko: '실시간 교실', hi: 'लाइव कक्षाएं', es: 'Aulas en vivo', fr: 'Classes en direct', ar: 'فصول مباشرة' },
    description: { zh: 'WebRTC 驅動的即時語言課堂，高清音視頻、互動白板、沉浸式學習。', en: 'WebRTC-powered live classrooms with HD audio/video and interactive whiteboard.', ja: 'WebRTC によるライブ語学クラス、HD 音声/映像、インタラクティブホワイトボードを提供します。', ko: 'WebRTC 기반 실시간 언어 수업, HD 오디오/비디오, 인터랙티브 화이트보드를 제공합니다.', hi: 'WebRTC आधारित लाइव भाषा कक्षाएं, HD ऑडियो/वीडियो और इंटरैक्टिव व्हाइटबोर्ड।', es: 'Aulas de idiomas en vivo con WebRTC, audio/video HD y pizarra interactiva.', fr: 'Classes de langues en direct via WebRTC avec audio/vidéo HD et tableau interactif.', ar: 'فصول لغة مباشرة عبر WebRTC مع صوت/فيديو عالي الدقة ولوح تفاعلي.' },
  },
  {
    icon: '🏆',
    title: { zh: '積分激勵', en: 'Points Incentive', ja: 'ポイントインセンティブ', ko: '포인트 보상', hi: 'पॉइंट प्रोत्साहन', es: 'Incentivos por puntos', fr: 'Incitation par points', ar: 'حوافز بالنقاط' },
    description: { zh: '學習賺取積分，鏈上記錄學習成果，NFT 證書認證。', en: 'Earn points through learning, on-chain achievement records, NFT certificates.', ja: '学習でポイントを獲得し、成果をオンチェーンに記録し、NFT 証明書を受け取れます。', ko: '학습으로 포인트를 얻고 성과를 온체인에 기록하며 NFT 인증서를 발급합니다.', hi: 'सीखकर पॉइंट कमाएं, उपलब्धियां ऑन-चेन दर्ज करें और NFT प्रमाणपत्र पाएं।', es: 'Gana puntos aprendiendo, registra logros on-chain y recibe certificados NFT.', fr: 'Gagnez des points, enregistrez vos progrès on-chain et obtenez des certificats NFT.', ar: 'اكسب نقاطًا عبر التعلم وسجّل الإنجازات على السلسلة واحصل على شهادات NFT.' },
  },
  {
    icon: '👥',
    title: { zh: '語言交換', en: 'Language Exchange', ja: '言語交換', ko: '언어 교환', hi: 'भाषा विनिमय', es: 'Intercambio de idiomas', fr: 'Échange linguistique', ar: 'تبادل اللغات' },
    description: { zh: '與母語者 1 對 1 語言交換練習，AI 輔助糾錯和翻譯。', en: '1-on-1 language exchange with native speakers, AI-assisted corrections.', ja: 'ネイティブスピーカーとの 1 対 1 言語交換を、AI による訂正で支援します。', ko: '원어민과 1:1 언어 교환을 하고 AI가 교정과 번역을 돕습니다.', hi: 'मूल वक्ताओं के साथ 1-से-1 भाषा अभ्यास और AI-सहायता सुधार।', es: 'Intercambio 1 a 1 con hablantes nativos y correcciones asistidas por IA.', fr: 'Échange 1:1 avec des natifs et corrections assistées par IA.', ar: 'تبادل لغة فردي مع متحدثين أصليين وتصحيح بمساعدة الذكاء الاصطناعي.' },
  },
  {
    icon: '📊',
    title: { zh: '學習追蹤', en: 'Learning Tracking', ja: '学習トラッキング', ko: '학습 추적', hi: 'लर्निंग ट्रैकिंग', es: 'Seguimiento del aprendizaje', fr: 'Suivi d’apprentissage', ar: 'تتبع التعلم' },
    description: { zh: '全面的學習資料儀表板、進度追蹤、個人化學習路徑推薦。', en: 'Comprehensive dashboard with progress tracking and personalized learning paths.', ja: '進捗管理とパーソナライズされた学習パスを備えた総合ダッシュボード。', ko: '학습 데이터 대시보드, 진도 추적, 개인화 학습 경로 추천을 제공합니다.', hi: 'प्रगति ट्रैकिंग और व्यक्तिगत सीखने के मार्गों वाला व्यापक डैशबोर्ड।', es: 'Panel completo con seguimiento de progreso y rutas de aprendizaje personalizadas.', fr: 'Tableau de bord complet avec suivi des progrès et parcours personnalisés.', ar: 'لوحة تعلم شاملة مع تتبع التقدم ومسارات تعلم مخصصة.' },
  },
];
---

<BaseLayout lang={lang} title={product.name[lang]} description={product.description[lang]}>
  <section class="px-5 pb-12 pt-16 sm:px-6 md:pt-24">
    <div class="mx-auto max-w-7xl">
      <a href={`/${lang}`} class="mb-8 inline-flex text-sm font-semibold text-muted-foreground transition-colors hover:text-primary">
        {t('products.back')}
      </a>
      <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <div>
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">{t('products.eyebrow')}</p>
          <h1 class="text-4xl font-bold tracking-tight md:text-6xl">{product.name[lang]}</h1>
        </div>
        <p class="max-w-2xl text-lg leading-8 text-muted-foreground">{product.description[lang]}</p>
      </div>
    </div>
  </section>

  <section class="px-5 pb-12 sm:px-6">
    <div class="mx-auto max-w-7xl">
      <h2 class="mb-8 text-3xl font-bold tracking-tight">{t('products.features')}</h2>
      <FeatureList features={features} lang={lang} client:load />
    </div>
  </section>

  <section class="px-5 pb-24 sm:px-6">
    <div class="mx-auto max-w-7xl">
      <DownloadSection lang={lang} product={product} client:load />
    </div>
  </section>
</BaseLayout>
