---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FeatureList from '../../../components/product/FeatureList.tsx';
import DownloadSection from '../../../components/product/DownloadSection.tsx';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { langs } from '../../../i18n/dict';
import { products } from '../../../config/downloads';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const product = products.find(p => p.slug === 'social')!;

const features = [
  {
    icon: '💬',
    title: { zh: '即时通讯', en: 'Instant Messaging' },
    description: { zh: '私聊、群聊、社区频道，消息实时同步，支持已读状态与推送通知。', en: 'Private chat, group chat, and community channels with real-time sync and push notifications.' },
  },
  {
    icon: '🏛️',
    title: { zh: '超级社区', en: 'Super Communities' },
    description: { zh: '万人社区架构，频道管理，角色系统，成员管理一气呵成。', en: 'Massive community architecture with channels, roles, and member management.' },
  },
  {
    icon: '🔐',
    title: { zh: '代币门控', en: 'Token Gating' },
    description: { zh: 'NFT 和代币门控频道，链上身份验证，角色权限系统。', en: 'NFT and token-gated channels with on-chain identity verification.' },
  },
  {
    icon: '🤖',
    title: { zh: 'AI 摘要', en: 'AI Summarization' },
    description: { zh: '频道内容自动摘要，关键话题提取，代币和链接智能识别。', en: 'Auto-summarization of channel content with topic and token extraction.' },
  },
];
---

<BaseLayout lang={lang} title={product.name[lang]} description={product.description[lang]}>
  <section class="px-6 pb-12 pt-12">
    <div class="mx-auto max-w-4xl">
      <a href={`/${lang}`} class="mb-8 inline-flex text-sm text-[var(--color-text-secondary)] transition-colors hover:text-white">
        {t('products.back')}
      </a>
      <h1 class="mt-4 text-3xl font-bold md:text-4xl">{product.name[lang]}</h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-[var(--color-text-secondary)]">{product.description[lang]}</p>
    </div>
  </section>

  <section class="px-6 pb-12">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-8 text-2xl font-bold">{lang === 'zh' ? '核心功能' : 'Core Features'}</h2>
      <FeatureList features={features} lang={lang} client:load />
    </div>
  </section>

  <section class="px-6 pb-24">
    <div class="mx-auto max-w-4xl">
      <DownloadSection lang={lang} product={product} client:load />
    </div>
  </section>
</BaseLayout>
