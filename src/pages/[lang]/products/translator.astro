---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FeatureList from '../../../components/product/FeatureList.tsx';
import DownloadSection from '../../../components/product/DownloadSection.tsx';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { langs } from '../../../i18n/dict';
import { products } from '../../../config/downloads';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const product = products.find(p => p.slug === 'translator')!;

const features = [
  {
    icon: '🌐',
    title: { zh: '多语言翻译', en: 'Multilingual Translation' },
    description: { zh: '支持 100+ 语言实时互译，覆盖文本、语音和图片翻译场景。', en: 'Real-time translation across 100+ languages covering text, voice, and image.' },
  },
  {
    icon: '🎙️',
    title: { zh: '语音识别', en: 'Voice Recognition' },
    description: { zh: '高精度语音转文字，实时翻译输出，跨语言无障碍沟通。', en: 'High-accuracy speech-to-text with real-time translation output.' },
  },
  {
    icon: '📄',
    title: { zh: '文档翻译', en: 'Document Translation' },
    description: { zh: 'PDF、Word、PPT 等文档格式完整翻译，保留原始排版。', en: 'Full document translation for PDF, Word, PPT preserving original formatting.' },
  },
  {
    icon: '⚡',
    title: { zh: 'AI 驱动', en: 'AI Powered' },
    description: { zh: '基于最新大语言模型，上下文感知翻译，专业术语准确。', en: 'Context-aware translation powered by latest LLMs with precise terminology.' },
  },
];
---

<BaseLayout lang={lang} title={product.name[lang]} description={product.description[lang]}>
  <section class="px-5 pb-12 pt-16 sm:px-6 md:pt-24">
    <div class="mx-auto max-w-7xl">
      <a href={`/${lang}`} class="mb-8 inline-flex text-sm font-semibold text-muted-foreground transition-colors hover:text-primary">
        {t('products.back')}
      </a>
      <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
        <div>
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">Product</p>
          <h1 class="text-4xl font-bold tracking-tight md:text-6xl">{product.name[lang]}</h1>
        </div>
        <p class="max-w-2xl text-lg leading-8 text-muted-foreground">{product.description[lang]}</p>
      </div>
    </div>
  </section>

  <section class="px-5 pb-12 sm:px-6">
    <div class="mx-auto max-w-7xl">
      <h2 class="mb-8 text-3xl font-bold tracking-tight">{t('products.features')}</h2>
      <FeatureList features={features} lang={lang} client:load />
    </div>
  </section>

  <section class="px-5 pb-24 sm:px-6">
    <div class="mx-auto max-w-7xl">
      <DownloadSection lang={lang} product={product} client:load />
    </div>
  </section>
</BaseLayout>
