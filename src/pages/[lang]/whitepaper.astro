---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl } from '../../i18n/utils';
import { langs } from '../../i18n/dict';
import { getWhitepaper } from '../../content/whitepaper.mjs';

export function getStaticPaths() {
  return langs.map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const paper = getWhitepaper(lang);
---

<BaseLayout lang={lang} title={paper.title} description={paper.summary}>
  <section class="px-5 pb-16 pt-16 sm:px-6 md:pt-24">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
        <div class="lg:sticky lg:top-28">
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">
            {paper.version}
          </p>
          <h1 class="max-w-3xl text-4xl font-bold tracking-tight md:text-6xl">{paper.title}</h1>
          <p class="mt-4 text-xl font-semibold text-primary">{paper.label}</p>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-muted-foreground">{paper.tagline}</p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={paper.downloadHref}
              download
              class="inline-flex h-11 items-center gap-2 rounded-lg bg-primary px-6 text-sm font-bold text-primary-foreground transition-all hover:-translate-y-0.5 hover:bg-primary/90"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              {paper.download}
            </a>
            <a
              href="#chapters"
              class="inline-flex h-11 items-center rounded-lg border border-white/10 bg-white/[0.035] px-6 text-sm font-bold text-foreground transition-all hover:-translate-y-0.5 hover:border-primary/35"
            >
              {paper.toc}
            </a>
          </div>

          <div class="mt-8 rounded-xl border border-white/10 bg-white/[0.035] p-5">
            <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-primary/80">
              {paper.disclaimerTitle}
            </h2>
            <p class="mt-3 text-sm leading-7 text-muted-foreground">{paper.disclaimer}</p>
          </div>
        </div>

        <article class="space-y-8">
          <div class="rounded-xl border border-white/10 bg-white/[0.035] p-6 md:p-8">
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-primary/80">
              {paper.summaryTitle}
            </p>
            <p class="text-lg leading-8 text-muted-foreground">{paper.summary}</p>
          </div>

          <nav id="chapters" class="rounded-xl border border-white/10 bg-white/[0.035] p-6 md:p-8">
            <h2 class="mb-5 text-sm font-semibold uppercase tracking-[0.18em] text-primary/80">{paper.toc}</h2>
            <div class="grid gap-2 sm:grid-cols-2">
              {paper.sections.map(section => (
                <a
                  href={`#${section.id}`}
                  class="group flex gap-3 rounded-lg border border-white/10 bg-background/65 p-3 text-sm transition-all hover:-translate-y-0.5 hover:border-primary/35 hover:bg-white/[0.055]"
                >
                  <span class="font-mono text-xs text-primary/80">{section.number}</span>
                  <span class="font-semibold text-muted-foreground transition-colors group-hover:text-foreground">
                    {section.title}
                  </span>
                </a>
              ))}
            </div>
          </nav>

          <div class="space-y-5">
            {paper.sections.map(section => (
              <section id={section.id} class="scroll-mt-28 rounded-xl border border-white/10 bg-white/[0.035] p-6 md:p-8">
                <p class="mb-3 font-mono text-xs font-semibold text-primary/80">{section.number}</p>
                <h2 class="text-2xl font-bold tracking-tight md:text-3xl">{section.title}</h2>
                <div class="mt-5 space-y-4">
                  {section.body.map(paragraph => (
                    <p class="text-base leading-8 text-muted-foreground">{paragraph}</p>
                  ))}
                </div>

                {section.table && (
                  <div class="mt-6 overflow-hidden rounded-lg border border-white/10">
                    <table class="w-full border-collapse text-left text-sm">
                      <thead class="bg-primary/10 text-primary">
                        <tr>
                          {section.table.headers.map(header => (
                            <th class="px-4 py-3 font-semibold">{header}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {section.table.rows.map(row => (
                          <tr class="border-t border-white/10">
                            {row.map(cell => (
                              <td class="px-4 py-3 text-muted-foreground">{cell}</td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </section>
            ))}
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
