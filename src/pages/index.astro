---
// Static redirect: client-side language detection for static hosting
// Falls back to /zh if no JS or language detection fails
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="refresh" content="0;url=/zh/" />
  <title>BBT Global</title>
</head>
<body>
  <script>
    (function() {
      var lang = navigator.language || navigator.userLanguage || '';
      var supported = ['zh', 'zh-cn', 'en', 'ja', 'ko', 'hi', 'es', 'fr', 'ar'];
      var normalized = lang.toLowerCase();
      var base = normalized.split('-')[0];
      var target = '/zh/';
      if (normalized === 'zh-cn' || normalized === 'zh-sg' || normalized === 'zh-hans') {
        target = '/zh-cn/';
      } else if (supported.indexOf(normalized) >= 0) {
        target = '/' + normalized + '/';
      } else if (supported.indexOf(base) >= 0) {
        target = '/' + base + '/';
      }
      window.location.replace(target);
    })();
  </script>
</body>
</html>
