---
// Static redirect: client-side language detection for static hosting
// Falls back to /zh if no JS or language detection fails
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="refresh" content="0;url=/zh/" />
  <title>BBT Global</title>
</head>
<body>
  <script>
    (function() {
      var lang = navigator.language || navigator.userLanguage || '';
      var supported = ['zh', 'en', 'ko', 'hi', 'es', 'fr', 'ar'];
      var base = lang.toLowerCase().split('-')[0];
      var target = supported.indexOf(base) >= 0 ? '/' + base + '/' : '/zh/';
      window.location.replace(target);
    })();
  </script>
</body>
</html>
